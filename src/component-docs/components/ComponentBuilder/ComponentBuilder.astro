---
/**
 * ComponentBuilder
 *
 * A visual drag-and-drop component builder for creating Astro components
 * by composing building blocks. Components can be configured, nested,
 * and exported as production-ready Astro component packages.
 */

import type { ComponentInfo, ComponentMetadata, NestingRules } from "./types";
import Button from "../../../components/building-blocks/core-elements/button/Button.astro";
import Slider from "../../../components/building-blocks/forms/slider/Slider.astro";

interface Props {
  components: ComponentInfo[];
  componentsByCategory: Record<string, ComponentInfo[]>;
  metadataMap: Record<string, ComponentMetadata>;
  nestedBlockProperties: string[];
  nestingRules: NestingRules;
  pageSectionCategories: string[];
  ssrEnabled?: boolean;
}

const {
  components,
  componentsByCategory,
  metadataMap,
  nestedBlockProperties,
  nestingRules,
  pageSectionCategories,
  ssrEnabled = false,
} = Astro.props;

// Serialize data for client
const builderData = {
  components,
  componentsByCategory,
  metadataMap,
  nestedBlockProperties,
  nestingRules,
  pageSectionCategories,
};
---

<div
  class="component-builder"
  data-builder-data={JSON.stringify(builderData)}
  data-ssr-enabled={String(ssrEnabled)}
>
  <!-- Template for reusable Slider component -->
  <template id="slider-template">
    <Slider
      id="slider-template-id"
      name="slider-template"
    />
  </template>

  <!-- Templates for reusable Button components -->
  <template id="button-ghost-template">
    <Button
      element="button"
      text="Button"
      variant="ghost"
      size="sm"
      class="sandbox-item-btn"
    />
  </template>

  <template id="button-delete-template">
    <Button
      element="button"
      text="Delete"
      iconName="trash"
      hideText={true}
      variant="ghost"
      size="md"
      class="sandbox-item-btn sandbox-item-btn-delete"
    />
  </template>

  <template id="button-close-template">
    <Button
      element="button"
      text="Close"
      iconName="x-mark"
      hideText={true}
      variant="ghost"
      size="lg"
      class="component-picker-close"
    />
  </template>

  <!-- Export Bar -->
  <div class="export-bar">
    <h1>Component Builder</h1>
    <div class="export-bar-actions">
      <Button
        element="button"
        text="Reset"
        variant="ghost"
        size="md"
        id="reset-btn"
      />
      <Button
        element="button"
        text="Export Component"
        variant="primary"
        size="md"
        id="export-btn"
        disabled
      />
    </div>
  </div>

  <div
    class="builder-view-toggle"
    id="builder-view-toggle"
  >
    <button
      type="button"
      class="builder-view-tab active"
      data-view="build"
      >Build</button
    >
    <button
      type="button"
      class="builder-view-tab"
      data-view="preview"
      id="preview-tab-btn"
      style="display: none;"
      >Preview</button
    >
    <button
      type="button"
      class="builder-view-tab"
      data-view="code"
      >Code</button
    >
  </div>

  <div
    class="builder-preview-container"
    id="builder-preview-container"
    style="display: none;"
  >
    <!-- Preview iframe injected here by JS -->
  </div>

  <div
    class="builder-code-container"
    id="builder-code-container"
    style="display: none;"
  >
    <div
      class="builder-code-tabs"
      id="builder-code-tabs"
    >
      <button
        type="button"
        class="builder-code-tab active"
        data-code-tab="astro"
        >Astro</button
      >
      <button
        type="button"
        class="builder-code-tab"
        data-code-tab="inputs"
        >Inputs YAML</button
      >
      <button
        type="button"
        class="builder-code-tab"
        data-code-tab="structure"
        >Structure Value</button
      >
    </div>
    <div class="builder-code-content">
      <button
        type="button"
        class="code-copy-btn"
        id="builder-code-copy"
        aria-label="Copy code"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 16 16"
          fill="currentColor"
        >
          <path
            d="M0 6.75C0 5.784.784 5 1.75 5h1.5a.75.75 0 0 1 0 1.5h-1.5a.25.25 0 0 0-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 0 0 .25-.25v-1.5a.75.75 0 0 1 1.5 0v1.5A1.75 1.75 0 0 1 9.25 16h-7.5A1.75 1.75 0 0 1 0 14.25Z"
          ></path>
          <path
            d="M5 1.75C5 .784 5.784 0 6.75 0h7.5C15.216 0 16 .784 16 1.75v7.5A1.75 1.75 0 0 1 14.25 11h-7.5A1.75 1.75 0 0 1 5 9.25Zm1.75-.25a.25.25 0 0 0-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 0 0 .25-.25v-7.5a.25.25 0 0 0-.25-.25Z"
          ></path>
        </svg>
      </button>
      <!-- Populated by JS with shiki-highlighted code -->
    </div>
  </div>

  <div
    class="builder-layout"
    id="builder-layout"
  >
    <!-- Main Builder Area -->
    <main class="builder-main">
      <div class="sandbox-container">
        <div
          class="sandbox"
          id="sandbox"
        >
          <!-- Rendered by JavaScript -->
        </div>
      </div>
    </main>

    <!-- Properties Sidebar (Right) -->
    <aside
      class="prop-sidebar"
      id="prop-sidebar"
    >
      <div
        class="sidebar-header"
        id="sidebar-header"
      >
        <div id="sidebar-title">Component Props</div>
      </div>
      <div
        class="sidebar-content"
        id="sidebar-content"
      >
        <p class="sidebar-empty">Select a component to edit its properties</p>
      </div>
    </aside>
  </div>

  <!-- Export Configuration Modal -->
  <div
    class="export-config-overlay"
    id="export-config-overlay"
    style="display: none;"
  >
    <div class="export-config-modal">
      <div class="export-config-header">
        <h2>Export Component</h2>
        <div id="export-config-close"></div>
      </div>
      <div class="export-config-content">
        <div
          class="export-config-field"
          id="page-section-category-field"
        >
          <label for="page-section-category">Category</label>
          <select
            id="page-section-category"
            class="export-config-select"
          >
            <!-- Populated by JavaScript -->
          </select>
          <div class="export-config-field-note">Or enter a custom category:</div>
          <input
            type="text"
            id="custom-page-section-category"
            class="export-config-input"
            placeholder="e.g., testimonials"
          />
        </div>

        <div class="export-config-field">
          <label for="component-name">Component Name</label>
          <input
            type="text"
            id="component-name"
            class="export-config-input"
            placeholder="my-component"
          />
          <div class="export-config-field-note">Use kebab-case (lowercase with hyphens)</div>
        </div>

        <div class="export-config-preview-group">
          <div class="export-config-preview-label">
            After downloading, unzip the file and place the component in:
          </div>
          <div class="export-config-preview">
            <code id="component-path-preview"
              >/src/components/page-sections/my-category/my-component</code
            >
          </div>
        </div>
      </div>
      <div
        class="export-preview-panel"
        id="export-preview-panel"
        style="display: none;"
      >
        <div class="export-preview-tabs">
          <button
            class="export-preview-tab active"
            data-tab="astro"
            type="button"
            >Astro</button
          >
          <button
            class="export-preview-tab"
            data-tab="inputs"
            type="button"
            >Inputs YAML</button
          >
          <button
            class="export-preview-tab"
            data-tab="structure"
            type="button"
            >Structure Value</button
          >
        </div>
        <div class="export-preview-code">
          <button
            type="button"
            class="code-copy-btn"
            id="export-code-copy"
            aria-label="Copy code"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 16 16"
              fill="currentColor"
            >
              <path
                d="M0 6.75C0 5.784.784 5 1.75 5h1.5a.75.75 0 0 1 0 1.5h-1.5a.25.25 0 0 0-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 0 0 .25-.25v-1.5a.75.75 0 0 1 1.5 0v1.5A1.75 1.75 0 0 1 9.25 16h-7.5A1.75 1.75 0 0 1 0 14.25Z"
              ></path>
              <path
                d="M5 1.75C5 .784 5.784 0 6.75 0h7.5C15.216 0 16 .784 16 1.75v7.5A1.75 1.75 0 0 1 14.25 11h-7.5A1.75 1.75 0 0 1 5 9.25Zm1.75-.25a.25.25 0 0 0-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 0 0 .25-.25v-7.5a.25.25 0 0 0-.25-.25Z"
              ></path>
            </svg>
          </button>
          <pre
            id="export-preview-code-content"><span class="line-numbers" id="export-line-numbers" /><code /></pre>
        </div>
      </div>
      <div class="export-config-footer">
        <Button
          element="button"
          text="Download ZIP"
          variant="primary"
          size="md"
          id="export-download-btn"
        />
      </div>
    </div>
  </div>
</div>

<script>
  import "./index";
</script>
