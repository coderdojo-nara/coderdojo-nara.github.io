---
import Component from "@components/utils/renderBlock.astro";
import type { ContentBlock } from "../../types";
import "@styles/style.css";
import SiteFonts from "@layouts/SiteFonts.astro";

export const prerender = false;

let contentSections: ContentBlock[] = [];

if (Astro.request.url) {
  const requestUrl = new URL(Astro.request.url);
  const treeParam = requestUrl.searchParams.get("tree");

  if (treeParam) {
    try {
      contentSections = JSON.parse(treeParam);
    } catch {
      // Invalid tree data
    }
  }
}
---

<html
  lang="en"
  data-theme="light"
>
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />
    <title>Builder Preview</title>
    <style is:inline>
      @layer reset, base, components, page-sections, utils, overrides;
    </style>
    <SiteFonts />
  </head>
  <body style="margin: 0;">
    {
      contentSections.length > 0 ? (
        <Component
          contentSections={contentSections}
          useDefaultEditableBinding={false}
        />
      ) : (
        <p style="color: #94a3b8; padding: 2rem; text-align: center;">
          Preview will appear here when you add components.
        </p>
      )
    }
  </body>
</html>
