---
const id = `gallery-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="gallery" data-gallery-id={id}>
  <slot />
</div>

<style>
  .gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);

    @media (min-width: 640px) {
      grid-template-columns: repeat(4, 1fr);
    }
    gap: var(--spacing-xs);
    margin-top: var(--spacing-xl);
    margin-bottom: var(--spacing-xl);
  }

  .gallery :global(p) {
    display: contents;
  }

  .gallery :global(img) {
    width: 100%;
    height: 140px;
    object-fit: cover;
    border-radius: var(--radius-sm);
    display: block;
    cursor: pointer;
  }

  /* ライトボックス（body直下に1つだけ生成） */
  :global(.lightbox) {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.85);
    z-index: 9999;
    align-items: center;
    justify-content: center;
  }

  :global(.lightbox.is-open) {
    display: flex;
  }

  :global(.lightbox-img) {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: var(--radius-md);
  }

  :global(.lightbox-close) {
    position: absolute;
    top: 1rem;
    right: 1.5rem;
    background: none;
    border: none;
    color: white;
    font-size: 2.5rem;
    line-height: 1;
    cursor: pointer;
    padding: 0;
  }
</style>

<script>
  // ライトボックスをbody直下に1つだけ生成
  function getLightbox(): HTMLElement {
    let lb = document.getElementById("gallery-lightbox");
    if (!lb) {
      lb = document.createElement("div");
      lb.id = "gallery-lightbox";
      lb.className = "lightbox";
      lb.innerHTML = `
        <button class="lightbox-close" aria-label="閉じる">&times;</button>
        <img class="lightbox-img" src="" alt="" />
      `;
      document.body.appendChild(lb);

      const img = lb.querySelector(".lightbox-img") as HTMLImageElement;

      lb.addEventListener("click", (e) => {
        if (e.target === lb || (e.target as HTMLElement).classList.contains("lightbox-close")) {
          lb!.classList.remove("is-open");
          img.src = "";
        }
      });

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && lb!.classList.contains("is-open")) {
          lb!.classList.remove("is-open");
          img.src = "";
        }
      });
    }
    return lb;
  }

  document.querySelectorAll<HTMLElement>(".gallery[data-gallery-id]").forEach((gallery) => {
    gallery.querySelectorAll("img").forEach((img) => {
      img.addEventListener("click", () => {
        const lb = getLightbox();
        const lbImg = lb.querySelector(".lightbox-img") as HTMLImageElement;
        lbImg.src = img.src;
        lbImg.alt = img.alt;
        lb.classList.add("is-open");
      });
    });
  });
</script>
