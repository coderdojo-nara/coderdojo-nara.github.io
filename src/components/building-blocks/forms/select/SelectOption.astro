---
const {
  value = "",
  label = "",
  selected = false,
  disabled = false,
  useDefaultEditableBinding: _useDefaultEditableBinding = false,
  _component,
  ...htmlAttributes
} = Astro.props;
---

<option
  value={value}
  selected={selected}
  disabled={disabled}
  {...htmlAttributes}
>
  {label}
  <slot />
</option>
