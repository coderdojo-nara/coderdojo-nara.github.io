---
import Component from "@components/utils/renderBlock.astro";
import { slugifyLabel } from "@components/utils/slugify";
import Button from "@core-elements/button/Button.astro";

const {
  label,
  triggerText,
  triggerVariant = "primary",
  triggerSize = "md",
  triggerIconName,
  size = "md",
  contentSections,
  useDefaultEditableBinding = false,
  class: className,
  "data-children-prop": childrenDataProp,
  _component,
  ...htmlAttributes
} = Astro.props;

const generatedLabel = label || `Modal-${crypto.randomUUID()}`;
const popoverId = `modal-${slugifyLabel(generatedLabel)}`;

const effectiveChildrenProp =
  childrenDataProp ?? (useDefaultEditableBinding ? "contentSections" : null);
const arrayDataAttributes = effectiveChildrenProp
  ? { "data-editable": "array", "data-prop": effectiveChildrenProp }
  : {};

const hasContentSections = contentSections?.length > 0;
const hasSlotContent = Astro.slots.has("default");
const hasTrigger = triggerText?.trim().length > 0 || triggerIconName?.trim().length > 0;

if (!_component && !hasContentSections && !hasSlotContent) return;
---

<div
  class:list={["modal", className]}
  {...htmlAttributes}
>
  {
    hasTrigger && (
      <Button
        text={triggerText}
        variant={triggerVariant}
        size={triggerSize}
        iconName={triggerIconName}
        element="button"
        class="modal-trigger"
        popovertarget={popoverId}
      />
    )
  }

  <div
    id={popoverId}
    popover="auto"
    class:list={["modal-popover", `size-${size}`]}
    role="dialog"
    aria-label={label}
  >
    <div class="modal-header">
      <Button
        iconName="x-mark"
        hideText
        text="Close"
        variant="ghost"
        size="lg"
        element="button"
        class="modal-close"
        popovertarget={popoverId}
        popovertargetaction="hide"
      />
    </div>
    <div
      class="modal-body"
      {...arrayDataAttributes}
    >
      <slot>
        {
          contentSections && (
            <Component
              contentSections={contentSections}
              useDefaultEditableBinding={!!effectiveChildrenProp}
            />
          )
        }
      </slot>
    </div>
  </div>
</div>

<script>
  import { onPageLoad } from "@component-utils/onPageLoad";

  function setupModals() {
    document.querySelectorAll<HTMLElement>(".modal").forEach((modal) => {
      if (modal.hasAttribute("data-modal-initialized")) return;
      modal.setAttribute("data-modal-initialized", "");

      const trigger = modal.querySelector<HTMLButtonElement>(".modal-trigger .button-inner");
      const popover = modal.querySelector<HTMLElement>(".modal-popover");
      if (!trigger || !popover) return;

      popover.addEventListener("toggle", (e) => {
        const { newState } = e as ToggleEvent;
        trigger.setAttribute("aria-expanded", String(newState === "open"));

        if (newState === "closed") {
          trigger.focus();
        }
      });
    });
  }

  onPageLoad(setupModals);
</script>

<style>
  @layer components {
    .modal {
      display: inline-flex;
      margin-top: var(--spacing-lg);
    }

    .modal-popover {
      background-color: var(--color-bg);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-xs);
      box-shadow: 0 16px 48px rgba(0, 0, 0, 0.2);
      color: var(--color-text);
      inset: 0;
      margin: auto;
      max-height: 85vh;
      overflow-y: auto;
      padding: 0;
      width: 90vw;

      opacity: 0;
      transform: translateY(16px);
      transition:
        opacity var(--animation-normal) ease-out,
        transform var(--animation-normal) ease-out,
        overlay var(--animation-normal) ease-out allow-discrete,
        display var(--animation-normal) ease-out allow-discrete;

      &:popover-open {
        opacity: 1;
        transform: translateY(0);

        @starting-style {
          opacity: 0;
          transform: translateY(16px);
        }
      }

      &::backdrop {
        background-color: var(--color-overlay);
        opacity: 0;
        transition:
          opacity var(--animation-normal) ease-out,
          overlay var(--animation-normal) ease-out allow-discrete,
          display var(--animation-normal) ease-out allow-discrete;
      }

      &:popover-open::backdrop {
        opacity: 1;

        @starting-style {
          opacity: 0;
        }
      }

      &.size-sm {
        max-width: var(--content-width-sm);
      }

      &.size-md {
        max-width: var(--content-width-md);
      }

      &.size-lg {
        max-width: var(--content-width-lg);
      }

      &.size-xl {
        max-width: var(--content-width-xl);
      }
    }

    .modal-header {
      display: flex;
      justify-content: flex-end;
      padding: var(--spacing-sm) var(--spacing-sm) 0;
      position: sticky;
      top: 0;
      z-index: var(--layer-1);
    }

    .modal-body {
      padding: 0 var(--spacing-lg) var(--spacing-lg);

      > :global(*:first-child) {
        margin-top: 0 !important;
      }

      > :global(*:last-child) {
        margin-bottom: 0 !important;
      }
    }
  }
</style>
