---
import RenderBlock from "@components/utils/renderBlock.astro";
import Heading from "@core-elements/heading/Heading.astro";

const {
  title,
  subtext,
  iconName,
  contentSections,
  useDefaultEditableBinding = false,
  checked = false,
  groupName = "content-selector-tabs",
  navigationPosition = "start",
  _component,
  "data-children-prop": childrenDataProp,
  ...htmlAttributes
} = Astro.props;

const uniqueId = crypto.randomUUID();
const tabId = `tab-${uniqueId}`;
const panelId = `panel-${uniqueId}`;
const tabLabelId = `tablabel-${uniqueId}`;

const effectiveChildrenProp =
  childrenDataProp ?? (useDefaultEditableBinding ? "contentSections" : null);
const arrayDataAttributes = effectiveChildrenProp
  ? { "data-editable": "array", "data-prop": effectiveChildrenProp }
  : {};
---

<div
  class="content-selector-item"
  {...htmlAttributes}
>
  <input
    type="radio"
    name={groupName}
    id={tabId}
    class="content-selector-input"
    checked={checked}
    autocomplete="off"
  />
  <label
    class="content-selector-tab"
    id={tabLabelId}
    for={tabId}
    role="tab"
    aria-controls={panelId}
    aria-selected={checked ? "true" : "false"}
    tabindex="0"
  >
    <Heading
      text={title}
      level="h3"
      size="h3"
      iconName={iconName}
      alignX={navigationPosition === "top" ? "center" : "start"}
      class="content-selector-tab-heading"
    />
    {
      subtext && (
        <span
          class:list={[
            "content-selector-tab-subtext",
            `align-${navigationPosition === "top" ? "center" : "start"}`,
          ]}
        >
          {subtext}
        </span>
      )
    }
  </label>
  <div
    class="content-selector-panel"
    id={panelId}
    role="tabpanel"
    aria-labelledby={tabLabelId}
    aria-hidden={checked ? "false" : "true"}
  >
    <div
      class="content-selector-panel-content"
      {...arrayDataAttributes}
    >
      <slot>
        {
          contentSections && (
            <RenderBlock
              contentSections={contentSections}
              useDefaultEditableBinding={!!effectiveChildrenProp}
            />
          )
        }
      </slot>
    </div>
  </div>
</div>

<style>
  @layer components {
    .content-selector-item {
      display: contents;
    }

    .content-selector-input {
      display: none;
    }

    .content-selector-tab {
      background: transparent;
      border: none;
      cursor: pointer;
      display: block;
      padding: var(--spacing-md);
      position: relative;
      transition: background-color var(--animation-normal) ease-in-out;

      &::before {
        background: transparent;
        content: "";
        position: absolute;
        transition:
          transform var(--animation-normal),
          background var(--animation-normal);
      }

      &:hover {
        background: var(--color-state-hover);
      }

      > :global(.content-selector-tab-heading) {
        margin: 0;
      }
    }

    .content-selector-tab-subtext {
      color: var(--color-text-muted);
      display: block;
      font-size: var(--font-size-body-sm);
      margin-top: var(--spacing-2xs);

      &.align-center {
        text-align: center;
      }

      &.align-start {
        text-align: start;
      }
    }

    .content-selector-input:checked + .content-selector-tab::before {
      background: var(--color-border-strong);
    }

    .content-selector-input:checked + .content-selector-tab + .content-selector-panel {
      display: block;
    }

    .content-selector-panel {
      animation: fade-in var(--animation-slow) ease-in-out forwards;
      container-type: inline-size;
      display: none;
    }

    .content-selector-panel-content > :global(*:first-child) {
      margin-top: 0 !important;
    }
  }
</style>
