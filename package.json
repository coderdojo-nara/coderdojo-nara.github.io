{
  "name": "coderdojo-nara",
  "type": "module",
  "version": "1.0.0",
  "description": "CoderDojo 奈良 公式サイト",
  "keywords": [
    "coderdojo",
    "astro",
    "nara"
  ],
  "author": "CoderDojo 奈良",
  "license": "MIT",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "DISABLE_COMPONENT_LIBRARY=true astro build",
    "build:with-library": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "npm run lint && npm run format",
    "check:fix": "npm run lint:fix && npm run format:fix",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:yml",
    "lint:js": "eslint .",
    "lint:yml": "eslint \"**/*.{yml,yaml}\"",
    "lint:fix": "npm run lint:js:fix && npm run lint:css:fix && npm run lint:yml:fix",
    "lint:js:fix": "eslint . --fix",
    "lint:yml:fix": "eslint \"**/*.{yml,yaml}\" --fix",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:css:fix": "stylelint \"**/*.css\" --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "dependencies": {
    "@astrojs/compiler-rs": "^0.1.6",
    "@astrojs/mdx": "^5.0.2",
    "@astrojs/node": "^10.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.1",
    "@choctawnationofoklahoma/lite-vimeo": "^1.3.1",
    "@cloudcannon/editable-regions": "^0.0.12",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/raleway": "^5.2.8",
    "@justinribeiro/lite-youtube": "^1.9.0",
    "@types/js-yaml": "^4.0.9",
    "astro": "^6.0.7",
    "astro-icon": "^1.1.5",
    "astro-seo": "^1.1.0",
    "embla-carousel": "^8.6.0",
    "embla-carousel-auto-scroll": "^8.6.0",
    "embla-carousel-autoplay": "^8.6.0",
    "glob": "^13.0.6",
    "js-beautify": "^1.15.4",
    "js-yaml": "^4.1.1",
    "jszip": "^3.10.1",
    "lightningcss": "^1.32.0",
    "markdown-it": "^14.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype-external-links": "^3.0.0",
    "sharp": "^0.34.5",
    "shiki": "^4.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^9.39.4",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-yml": "^3.3.1",
    "jsonc-eslint-parser": "^3.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "stylelint": "^17.5.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "yaml-eslint-parser": "^2.0.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "optionalDependencies": {
    "@img/sharp-linux-x64": "^0.34.5",
    "@img/sharp-linuxmusl-x64": "^0.34.5",
    "@rollup/rollup-linux-x64-gnu": "^4.59.0",
    "@rollup/rollup-win32-x64-msvc": "^4.59.0"
  }
}
